{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "mode": "full",
  "prCreation": "not-pending",
  "internalChecksFilter": "strict",
  "ignoreDeps": [
    "org.apache.groovy:groovy",
    "org.apache.groovy:groovy-all",
    "org.junit.platform:junit-platform-launcher",
    "astroid",
    "@eslint/js",
    "eslint",
    "typescript"
  ]
}
