{
  "name": "rulebook-eslint",
  "version": "0.3.0",
  "description": "Aggressive source code linter extensions",
  "homepage": "https://github.com/hanggrian/rulebook#readme",
  "bugs": {
    "url": "https://github.com/hanggrian/rulebook/issues"
  },
  "repository": "hanggrian/rulebook",
  "license": "Apache-2.0",
  "author": "Hendra Anggrian <hanggrian@proton.me>",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "resources"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src/",
    "test": "vitest run",
    "coverage": "vitest run --coverage --reporter=junit --outputFile=test-report.junit.xml",
    "prepublishOnly": "cp ../README.md ./",
    "postpublish": "rm ./README.md"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-sort-class-members": "^1.21.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/estree": "1.0.8",
    "@types/node": "25.6.0",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-sort-class-members": "1.22.1",
    "testing": "workspace:*"
  }
}
