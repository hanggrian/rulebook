{
  "name": "rulebook-typescript-eslint",
  "version": "0.3.0",
  "description": "Aggressive source code linter extensions",
  "homepage": "https://github.com/hanggrian/rulebook#readme",
  "bugs": {
    "url": "https://github.com/hanggrian/rulebook/issues"
  },
  "repository": "hanggrian/rulebook",
  "license": "Apache-2.0",
  "author": "Hendra Anggrian <hanggrian@proton.me>",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "resources"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src/",
    "test": "vitest run",
    "coverage": "vitest run --coverage --reporter=junit --outputFile=test-report.junit.xml",
    "prepublishOnly": "cp ../README.md ./",
    "postpublish": "rm ./README.md"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.58.1",
    "@typescript-eslint/utils": "^8.58.1",
    "rulebook-eslint": "workspace:*",
    "typescript-eslint": "^8.58.1"
  },
  "devDependencies": {
    "@types/estree": "1.0.9",
    "@types/node": "25.6.2",
    "@typescript-eslint/parser": "8.58.1",
    "@typescript-eslint/utils": "8.58.1",
    "rulebook-eslint": "workspace:*",
    "testing": "workspace:*",
    "typescript-eslint": "8.58.1"
  }
}
