{
  "name": "rulebook",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "pnpm -r build",
    "prelint": "pnpm -r lint",
    "lint": "stylebook *.json packages/**/*.json *.md website/",
    "predocumentation": "rm -rf build/typedoc/",
    "documentation": "typedoc --entryPointStrategy packages --out build/typedoc/ packages/rulebook-eslint/ packages/rulebook-typescript-eslint/"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "rulebook-eslint": "workspace:*",
    "rulebook-typescript-eslint": "workspace:*",
    "codecheck-js": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@hanggrian/stylebook": "0.1.0",
    "@prantlf/jsonlint": "17.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@stylistic/stylelint-plugin": "5.1.0",
    "@types/sinon": "21.0.1",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "10.4.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-sort-class-members": "1.22.1",
    "eslint-vitest-rule-tester": "3.1.0",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "htmlhint": "1.9.2",
    "markdownlint-cli2": "0.22.1",
    "sinon": "22.0.0",
    "stylelint": "17.11.1",
    "stylelint-config-recommended": "18.0.0",
    "typedoc": "0.28.19",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vitest": "4.1.6",
    "vitest-dom": "0.1.1"
  }
}
