{
  "name": "rulebook",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint rulebook-eslint/src/ rulebook-typescript-eslint/src/ sample/javascript/ sample/typescript/",
    "lint2": "eslint --config sample-configured/eslint.config.js sample-configured/javascript/",
    "doc": "typedoc --entryPointStrategy packages --out build/typedoc/ rulebook-eslint/ rulebook-typescript-eslint/"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/sinon": "^21.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-sort-class-members": "^1.21.0",
    "eslint-vitest-rule-tester": "^3.1.0",
    "globals": "^17.4.0",
    "sinon": "^21.0.3",
    "typedoc": "^0.28.18",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-dom": "^0.1.1"
  },
  "dependencies": {
    "codecheck": "workspace:*",
    "rulebook-eslint": "workspace:*",
    "rulebook-typescript-eslint": "workspace:*"
  }
}
