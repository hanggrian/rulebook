{
  "name": "stress-test",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "uv run pylint **/*.py --rcfile=../.pylintrc && eslint src/ && uv run stylebook *.toml && pnpm exec stylebook *.json",
    "test": "uv run pytest && vitest --run src/__tests__/**/*.ts"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "devDependencies": {
    "rulebook-eslint": "workspace:*",
    "rulebook-typescript-eslint": "workspace:*",
    "testing": "workspace:*"
  }
}
